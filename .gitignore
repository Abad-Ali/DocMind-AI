# =====================================================
# Root .gitignore
# Frontend: Next.js + Tailwind
# Backend: Express.js + Node.js
# =====================================================

# ----------------------
# Dependencies
# ----------------------
**/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ----------------------
# Environment variables
# ----------------------
**/.env
**/.env.local
**/.env.development
**/.env.production
**/.env.test
**/.env.*
!**/.env.example

# ----------------------
# Next.js (frontend)
# ----------------------
frontend/.next/
frontend/out/
frontend/build/

# ----------------------
# Tailwind / PostCSS
# ----------------------
**/.tailwindcss-cache/
**/.postcss-cache/

# ----------------------
# Backend (Express / Node)
# ----------------------
backend/logs/
backend/*.log
backend/*.pid
backend/*.pid.lock

# ----------------------
# Testing / Coverage
# ----------------------
**/coverage/
**/.nyc_output/

# ----------------------
# Cache / Temp
# ----------------------
**/.cache/
**/.tmp/
**/.temp/

# ----------------------
# TypeScript
# ----------------------
**/*.tsbuildinfo
frontend/next-env.d.ts

# ----------------------
# IDE / Editor
# ----------------------
.vscode/
.idea/
**/*.swp
**/*.swo
**/*.swn

# ----------------------
# OS files
# ----------------------
.DS_Store
Thumbs.db
Desktop.ini
